---
---
<section class="card" id="contact">
  <h2>Get in Touch</h2>
  <form action="mailto:rajat.m324@gmail.com" method="post" enctype="text/plain" class="max-w-2xl mx-auto space-y-6">
    <div>
      <label for="name" class="block font-bold mb-2 text-[var(--ink)]">Name</label>
      <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-[var(--border)] rounded-lg focus:outline-none focus:border-[var(--accent)]" />
    </div>
    <div>
      <label for="email" class="block font-bold mb-2 text-[var(--ink)]">Email</label>
      <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-[var(--border)] rounded-lg focus:outline-none focus:border-[var(--accent)]" />
    </div>
    <div>
      <label for="subject" class="block font-bold mb-2 text-[var(--ink)]">Subject</label>
      <input type="text" id="subject" name="subject" required class="w-full px-4 py-2 border border-[var(--border)] rounded-lg focus:outline-none focus:border-[var(--accent)]" />
    </div>
    <div>
      <label for="message" class="block font-bold mb-2 text-[var(--ink)]">Message</label>
      <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2 border border-[var(--border)] rounded-lg focus:outline-none focus:border-[var(--accent)]"></textarea>
    </div>
    <div class="text-center">
      <button type="submit" class="bg-[var(--accent)] hover:bg-[var(--accent-2)] text-white font-bold py-3 px-8 rounded-full transition-colors duration-300">
        Send Message
      </button>
    </div>
  </form>
</section>