      "Maintained and enhanced existing iOS application with new features",
      "Developed native ScreenTime framework features for digital monitoring",
      "Collaborated with product managers and designers for UI implementation"
    ],
    tags: ["iOS", "Swift", "ScreenTime"],
    image: `${import.meta.env.BASE_URL}images/ever-accountable-icon.png`,
    appLink: "https://apps.apple.com/in/app/ever-accountable-quit-porn/id1074047778"
  },
  {
    name: "DP360 CRM",
    description: [
