      "Successfully deployed and managed on App Store"
    ],
    tags: ["iOS", "Swift", "VIPER"],
    image: `${import.meta.env.BASE_URL}images/placeholder-icon.png`,
    appLink: "https://apps.apple.com/in/app/unbiasy/id6477892005"
  },
  {
    name: "GO: Car Booking App",
    description: [
