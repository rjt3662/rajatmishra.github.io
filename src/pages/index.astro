    ],
    tags: ["iOS", "Swift", "Clean Swift"],
    image: `${import.meta.env.BASE_URL}images/placeholder-icon.png`,
    appLink: "https://apps.apple.com/in/app/hoptale/id955358548"
  },
  {
    name: "EventMoon",
    description: [
      "Enhanced application performance through targeted optimisation",
      "Modernised UI and implemented new features using Swift",
      "Collaborated with team for feature integration",
      "Improved overall application functionality"
    ],
    tags: ["iOS", "Swift", "MVC"],
    image: `${import.meta.env.BASE_URL}images/placeholder-icon.png`,
    appLink: "https://apps.apple.com/in/app/eventmoon/id487922291"
  },
  {
    name: "Unbiasy News App",
    description: [
      "Developed native iOS application from ground up using Swift",
      "Created modular, scalable codebase using VIPER architecture",
