---
import ProfileLayout from '../layouts/ProfileLayout.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';

const profile = {
  name: "Rajat Mishra",
  role: "Mobile Engineer",
  summary:
    "9+ years building native and cross-platform apps that engage users and deliver results. Strong in Swift, Kotlin, React Native, and Flutter, with a focus on performance and efficiency.",
};

const experience = [
  {
    title: "Senior iOS Developer",
    company: "Freelance (Remote)",
    period: "May 2020 - Present",
    description:
      "Developed and launched 10+ mobile applications across industries, reducing delivery time by roughly 20% through efficient code practices, clear architecture, and agile execution.",
  },
  {
    title: "iOS Developer",
    company: "Bito1 Techplode, Ahmedabad, India",
    period: "Feb 2019 - Apr 2020",
    description:
      "Built and shipped native iOS features while maintaining shared Git workflows, managing pull requests, and coordinating delivery with cross-functional teams using JIRA and collaborative project tools.",
  },
  {
    title: "Junior iOS Developer",
    company: "Biztech, Ahmedabad, India",
    period: "Jan 2017 - Nov 2018",
    description:
      "Started in professional mobile development, collaborating with senior engineers to build and maintain production iOS applications, resolve issues quickly, and strengthen code quality fundamentals.",
  },
];

const projects = [
  {
